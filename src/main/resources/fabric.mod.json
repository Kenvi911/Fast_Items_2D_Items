{
  "schemaVersion": 1,
  "id": "fast-items",
  "version": "${version}",
  "name": "Fast Items",
  "description": "Optimize item rendering by transforming items to 2D",
  "authors": [
    "Kenvi",
    "Noryea (original author)"
  ],
  "contact": {
    "homepage": "https://modrinth.com/mod/fast-items-2d",
    "sources": "https://github.com/Kenvi911/Fast_Items_2D_Items",
    "issues": "https://github.com/Kenvi911/Fast_Items_2D_Items/issues"
  },
  "license": "ARR",
  "icon": "assets/fast-items/icon.png",
